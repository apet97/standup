# Required
PUMBLE_ADDON_MANIFEST_PATH=./manifest.json  # Path to Pumble addon manifest (string)

# Optional (with defaults)
PORT=5000                    # HTTP server port (integer, 1-65535)
DB_PATH=./standup.db         # SQLite database file path (string)
TOKEN_STORE_PATH=./tokens.json  # Pumble token store file path (string)
LOG_LEVEL=info               # Log level: trace, debug, info, warn, error, fatal (string)
RETENTION_DAYS=90            # Days to keep run/response data (integer, > 0)

# Pumble SDK (set by pumble-cli during development)
# PUMBLE_APP_ID=               # App ID (string)
# PUMBLE_APP_KEY=              # App key (string)
# PUMBLE_APP_CLIENT_SECRET=    # Client secret (string, sensitive)
# PUMBLE_APP_SIGNING_SECRET=   # Signing secret for request verification (string, sensitive)
