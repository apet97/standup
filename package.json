{
  "name": "standup-bot",
  "version": "1.1.0",
  "description": "Async standup/check-in bot for Pumble",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:backup": "npx tsx scripts/db-backup.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pumble-sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
